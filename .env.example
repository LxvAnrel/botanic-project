APP_NAME=Flora
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.railway.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# Para MySQL no Railway, descomente e configure:
# DB_CONNECTION=mysql
# DB_HOST=
# DB_PORT=3306
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Envio de email via Resend (API HTTP — porta 443, nao bloqueada por hosts).
# Preferida ao SMTP porque o Railway bloqueia portas SMTP (587/465).
MAIL_MAILER=resend
RESEND_API_KEY=                      # sua API key do Resend (re_...)
MAIL_FROM_ADDRESS="onboarding@resend.dev"   # troque por um endereco do seu dominio verificado
MAIL_FROM_NAME="${APP_NAME}"

# Remetentes por finalidade (precisam ser do dominio verificado no Resend).
# Padroes definidos em config/flora.php; descomente para sobrescrever.
# MAIL_FROM_SEGURANCA=seguranca@florabotanic.site
# MAIL_FROM_ACESSO=acesso@florabotanic.site
# MAIL_FROM_ALERTAS=alertas@florabotanic.site
# MAIL_FROM_OLA=ola@florabotanic.site
# MAIL_FROM_CONTATO=contato@florabotanic.site

VITE_APP_NAME="${APP_NAME}"

# Cloudinary — armazenamento das fotos de perfil (persistente).
# Pegue em cloudinary.com → Dashboard → "API Environment variable".
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Sem isso, o upload cai no disco local (efemero no Railway).
CLOUDINARY_URL=

# Web Push (notificacoes no celular) — gere com: php artisan webpush:vapid
# A chave privada NAO deve ser commitada; defina nas Variables do Railway.
VAPID_SUBJECT="mailto:seu-email@exemplo.com"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
