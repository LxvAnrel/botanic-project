APP_NAME=Flora
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.railway.app

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# Para MySQL no Railway, descomente e configure:
# DB_CONNECTION=mysql
# DB_HOST=
# DB_PORT=3306
# DB_DATABASE=railway
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Envio de email via Resend (SMTP) — usado na recuperacao de senha
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=                       # sua API key do Resend (re_...)
# Na porta 587 o STARTTLS e ativado automaticamente (nao use MAIL_ENCRYPTION no Laravel 11+)
MAIL_FROM_ADDRESS="onboarding@resend.dev"   # troque por um endereco do seu dominio verificado
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
